# ============================================================
# Noteworthy — Configuration
# ============================================================

# Security PIN for authentication
PIN_CODE=1234

# Google Gemini API Key (Required for note parsing & insights)
GEMINI_API_KEY=your_gemini_api_key_here

# Port to run the server on (Optional)
PORT=3000

# ------------------------------------------------------------
# SUPABASE CONFIGURATION (Optional)
# If left blank, the app will run completely locally for free
# using SQLite (noteworthy.db) and local image uploads.
# ------------------------------------------------------------
# SUPABASE_URL=your_supabase_url_here
# SUPABASE_SERVICE_KEY=your_supabase_service_role_key_here
